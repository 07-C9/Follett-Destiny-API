# Follett Destiny API credentials
# Get these from Destiny: Setup > API tab > create an API account with client credentials
DESTINY_CLIENT_ID=your_client_id_here
DESTINY_CLIENT_SECRET=your_client_secret_here

# Your Destiny API base URL
# Format: https://yourdistrict.follettdestiny.com/api/v1/rest/context/your-context-id
DESTINY_BASE_URL=https://yourdistrict.follettdestiny.com/api/v1/rest/context/destiny-XXXX-XXXX
